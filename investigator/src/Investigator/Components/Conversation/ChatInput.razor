<div class="chat-input">
    @if (IsInvestigating)
    {
        <div class="thinking-indicator">
            <span class="thinking-dot"></span>
            <span class="thinking-dot"></span>
            <span class="thinking-dot"></span>
            <span class="thinking-text">Little Bear is investigating...</span>
        </div>
    }
    else if (HasWorkingAgents)
    {
        <div class="agents-working-indicator">
            <span class="agents-working-text">Scouts are working in the background...</span>
        </div>
    }
    <div class="chat-input-row">
        <textarea @bind="_message" @bind:event="oninput"
                  @onkeydown="OnKeyDown"
                  placeholder="Describe the issue to investigate..."></textarea>
        <div class="chat-input-buttons">
            <button class="btn-send" @onclick="Send" disabled="@string.IsNullOrWhiteSpace(_message)">Send</button>
            @if (IsInvestigating)
            {
                <button class="btn-cancel" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsInvestigating { get; set; }
    [Parameter] public bool HasWorkingAgents { get; set; }

    private string _message = "";

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_message)) return;
        var msg = _message;
        _message = "";
        await OnSend.InvokeAsync(msg);
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }
}
