@inject IJSRuntime JS

<div class="chat-input">
    @if (IsInvestigating)
    {
        <div class="thinking-indicator">
            <span class="thinking-dot"></span>
            <span class="thinking-dot"></span>
            <span class="thinking-dot"></span>
            <span class="thinking-text">@(IsRemediation ? "Intendant Langur is attending to the matter..." : "Little Bear is on the case...")</span>
        </div>
    }
    else if (HasWorkingAgents)
    {
        <div class="agents-working-indicator">
            <span class="agents-working-text">The Scouts are pursuing inquiries...</span>
        </div>
    }
    <div class="chat-input-row">
        <textarea @ref="_textareaRef" @bind="_message" @bind:event="oninput"
                  @onkeydown="OnKeyDown"
                  placeholder="Describe your case..." disabled="@Disabled"></textarea>
        <div class="chat-input-buttons">
            @if (IsInvestigating)
            {
                <button class="btn-cancel" @onclick="CancelInvestigation" disabled="@_cancelling">Cancel</button>
            }
            <button class="btn-send" @onclick="Send" disabled="@(Disabled || string.IsNullOrWhiteSpace(_message))">Send</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsInvestigating { get; set; }
    [Parameter] public bool HasWorkingAgents { get; set; }
    [Parameter] public bool IsRemediation { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private ElementReference _textareaRef;
    private string _message = "";
    private bool _cancelling;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await JS.InvokeVoidAsync("initPasteHandler", _textareaRef);
        }
    }

    private async Task CancelInvestigation()
    {
        _cancelling = true;
        await OnCancel.InvokeAsync();
    }

    private async Task Send()
    {
        if (Disabled || string.IsNullOrWhiteSpace(_message)) return;
        var msg = _message;
        _message = "";
        await OnSend.InvokeAsync(msg);
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }
}
