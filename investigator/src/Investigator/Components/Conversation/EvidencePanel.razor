@using Investigator.Models
@using Investigator.Components.Shared

<div class="evidence-panel">
    <button class="panel-toggle" @onclick="Toggle">
        <span class="toggle-arrow">@(_expanded ? "▼" : "▶")</span> Evidence (@Evidence.Steps.Count steps)
    </button>

    @if (_expanded)
    {
        <div class="evidence-steps">
            @foreach (var step in Evidence.Steps)
            {
                <div class="evidence-step">
                    <div class="step-number">@step.Step</div>
                    <div class="step-body">
                        <div class="step-reasoning">@step.Reasoning</div>
                        <div class="step-finding">@step.Finding</div>
                        @if (!string.IsNullOrWhiteSpace(step.Cluster))
                        {
                            <span class="step-cluster">@step.Cluster</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(step.Source))
                        {
                            <span class="step-source" title="@step.Source">
                                @if (ConversationId is not null && IsLocalFile(step.Source))
                                {
                                    <a class="step-source-link" href="/api/conversations/@ConversationId/files/@step.Source" target="_blank">@StripPrefix(step.Source)</a>
                                }
                                else if (step.Source.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a class="step-source-link" href="@step.Source" target="_blank" rel="noopener">@StripPrefix(step.Source)</a>
                                }
                                else
                                {
                                    <span class="step-source-text">@StripPrefix(step.Source)</span>
                                }
                                <CopyButton Text="@step.Source" />
                            </span>
                        }
                        @if (!string.IsNullOrWhiteSpace(step.Proof))
                        {
                            <div class="step-proof">
                                <code>@step.Proof</code>
                                <CopyButton Text="@step.Proof" />
                            </div>
                        }
                        else
                        {
                            <div class="step-proof-missing">no raw evidence</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public EvidenceChain Evidence { get; set; } = default!;
    [Parameter] public string? ConversationId { get; set; }
    private bool _expanded;
    private void Toggle() => _expanded = !_expanded;

    private static readonly string[] s_prefixes = ["tool_outputs/", "/data/"];

    private static string StripPrefix(string source)
    {
        foreach (var p in s_prefixes)
        {
            if (source.StartsWith(p, StringComparison.OrdinalIgnoreCase))
                return source[p.Length..];
        }
        return source.TrimStart('/');
    }

    private static bool IsLocalFile(string source) =>
        source.StartsWith("tool_outputs/", StringComparison.OrdinalIgnoreCase);
}
