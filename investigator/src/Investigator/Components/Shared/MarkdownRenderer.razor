@using Markdig
@using System.Text.RegularExpressions

@if (Inline)
{
    <span class="markdown-body markdown-inline">@((MarkupString)_html)</span>
}
else
{
    <div class="markdown-body">@((MarkupString)_html)</div>
}

@code {
    private static readonly MarkdownPipeline s_pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private static readonly Regex s_blockWrapperRegex = new(
        @"^\s*<p>(.*)</p>\s*$", RegexOptions.Singleline | RegexOptions.Compiled);

    private static readonly Regex s_apiLinkRegex = new(
        @"<a\s+href=""(/api/[^""]*)"">", RegexOptions.Compiled);

    [Parameter, EditorRequired] public string Content { get; set; } = "";
    [Parameter] public bool Inline { get; set; }

    private string _lastContent = "";
    private bool _lastInline;
    private string _html = "";

    protected override void OnParametersSet()
    {
        if (string.Equals(Content, _lastContent, StringComparison.Ordinal) && Inline == _lastInline)
            return;
        _lastContent = Content ?? "";
        _lastInline = Inline;
        try
        {
            _html = Markdown.ToHtml(_lastContent, s_pipeline);
            _html = s_apiLinkRegex.Replace(_html,
                @"<a href=""$1"" target=""_blank"" data-enhance-nav=""false"">");
        }
        catch (ArgumentException)
        {
            _html = System.Net.WebUtility.HtmlEncode(_lastContent);
        }

        if (Inline)
        {
            _html = s_blockWrapperRegex.Replace(_html, "$1").Trim();
        }
    }
}
