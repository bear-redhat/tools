@inherits LayoutComponentBase
@using Investigator.Models
@using Investigator.Services
@inject NavigationManager Nav
@inject CircuitAuthState CircuitAuth
@inject AuthSettings AuthSettings

<div class="main-layout">
    <header class="top-bar">
        <div class="header-brand" @onclick="() => _showNewSessionModal = true">
            <img src="@Assets["little-bear.png"]" alt="Little Bear" class="header-logo" />
            <h1>Little Bear, the Detective</h1>
        </div>
        @if (AuthSettings.Mode != AuthMode.None)
        {
            <div class="user-info">
                @if (CircuitAuth.IsAuthenticated)
                {
                    <span>@CircuitAuth.UserName</span>
                    @if (CircuitAuth.AuthMethod == AuthMode.Oidc)
                    {
                        <a href="/logout" class="logout-link">Sign out</a>
                    }
                }
                else
                {
                    <span>not signed in</span>
                }
            </div>
        }
    </header>
    <main>
        @Body
    </main>
</div>

@if (_showNewSessionModal)
{
    <div class="modal-backdrop" @onclick="() => _showNewSessionModal = false">
        <div class="modal-card" @onclick:stopPropagation>
            <h2>Begin a new investigation?</h2>
            <p>The current investigation will be permanently lost.</p>
            <div class="modal-actions">
                <button class="btn-modal-cancel" @onclick="() => _showNewSessionModal = false">Cancel</button>
                <button class="btn-modal-confirm" @onclick="StartNewSession">New Session</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _showNewSessionModal;

    private void StartNewSession()
    {
        Nav.NavigateTo("/", forceLoad: true);
    }
}
