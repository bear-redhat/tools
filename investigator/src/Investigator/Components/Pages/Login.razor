@page "/login"
@using Investigator.Models
@using Investigator.Services
@using Microsoft.Extensions.Options
@inject CircuitAuthState CircuitAuth
@inject AuthSettings AuthSettings
@inject NavigationManager Nav
@inject IOptions<AuthOptions> AuthOpts
@inject ConversationStore Store

<PageTitle>The Game Is Afoot - Investigator</PageTitle>

<div class="login-container">
    <div class="login-card">
        @if (_success)
        {
            <div class="login-art login-art--success">
                <div class="art-header">221B Banyan Hollow</div>
                <div class="art-flora">🌿 🔥 🌿</div>
                <div class="art-bear">🐻</div>
                <div class="art-magnifier">🐾</div>
                <div class="art-footer">The game is afoot. Welcome, Client.</div>
            </div>
        }
        else if (_error)
        {
            <div class="login-art login-art--error">
                <div class="art-header">221B Banyan Hollow</div>
                <div class="art-flora">🍂 🕯️ 🍂</div>
                <div class="art-bear">🐻</div>
                <div class="art-magnifier">✋</div>
                <div class="art-footer">That letter of introduction doesn't check out.</div>
            </div>
        }
        else if (_oidcRedirecting)
        {
            <div class="login-art login-art--success login-art--active">
                <div class="art-header">221B Banyan Hollow</div>
                <div class="art-flora">🌿 🏮 🌿</div>
                <div class="art-bear">🐻</div>
                <div class="art-magnifier">🕊️</div>
                <div class="art-footer">A telegram has been dispatched...</div>
            </div>
        }
        else if (_showTokenInput)
        {
            <div class="login-art login-art--active">
                <div class="art-header">221B Banyan Hollow</div>
                <div class="art-flora">🌿 🏮 🌿</div>
                <div class="art-bear">🐻</div>
                <div class="art-magnifier">✉️</div>
                <div class="art-footer">Let us see this letter of yours...</div>
            </div>
        }
        else
        {
            <div class="login-art">
                <div class="art-header">221B Banyan Hollow</div>
                <div class="art-flora">🌿 🏮 🌿</div>
                <div class="art-bear">🐻</div>
                <div class="art-magnifier">🔎</div>
                <div class="art-footer">🐾 Knock, knock. 🐾</div>
            </div>
        }

        @if (AuthSettings.HasOidc && !_showTokenInput)
        {
            <button class="login-button" @onclick="RedirectToOidc">📜 I Bear a Letter from Abroad</button>
        }

        @if (AuthSettings.HasToken)
        {
            @if (!_showTokenInput)
            {
                <button class="login-button" @onclick="() => _showTokenInput = true">✉️ I Carry My Own Letter of Introduction</button>
            }
            else
            {
                <form @onsubmit="Submit" @onsubmit:preventDefault>
                    <input type="password" @bind="_token" placeholder="Unseal your letter..." class="login-input" autofocus />
                    <button type="submit" class="login-button">📜 Present the Letter</button>
                </form>
            }
        }

        @if (AuthSettings.Mode == AuthMode.None)
        {
            <p class="login-hint">🚪 The door to 221B stands open. No letter of introduction required.</p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string _token = "";
    private bool _error;
    private bool _success;
    private bool _showTokenInput;
    private bool _oidcRedirecting;

    private async Task Submit()
    {
        var expected = AuthOpts.Value.SharedToken;
        if (!string.IsNullOrEmpty(expected) && _token == expected)
        {
            CircuitAuth.IsAuthenticated = true;
            CircuitAuth.UserName = "token-user";
            CircuitAuth.AuthMethod = AuthMode.Token;

            _error = false;
            _success = true;
            StateHasChanged();
            await Task.Delay(600);

            if (!string.IsNullOrEmpty(ReturnUrl))
            {
                Nav.NavigateTo(ReturnUrl);
            }
            else
            {
                var session = Store.CreateSession();
                Nav.NavigateTo($"/c/{session.Id}");
            }
        }
        else
        {
            _error = true;
        }
    }

    private async Task RedirectToOidc()
    {
        _oidcRedirecting = true;
        StateHasChanged();
        await Task.Delay(600);
        Nav.NavigateTo($"/login/oidc?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}", forceLoad: true);
    }
}
