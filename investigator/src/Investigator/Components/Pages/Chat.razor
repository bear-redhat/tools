@page "/c/{ConversationId}"
@using Investigator.Models
@using Investigator.Services
@using Investigator.Components.Conversation
@using Investigator.Components.InvestigationLog
@using Investigator.Components.Remediation
@using Investigator.Components.Shared

<PageTitle>@(_isRemediation ? "The Canopy Post" : "Little Bear, the Detective")</PageTitle>

@if (_sessionNotFound)
{
    <div class="session-not-found">
        <p>This investigation session was not found or has ended.</p>
    </div>
    return;
}

<div class="chat-page @(!_isOwner ? "readonly" : "")">

@if (!_isOwner && _session is not null)
{
    <div class="readonly-banner">
        <span>Viewing a shared record of this investigation (read-only)</span>
        @if (!_forcedReadonly)
        {
            <button class="btn-refresh" @onclick="Refresh">Refresh</button>
        }
    </div>
}

<div class="investigator-layout">
    <div class="conversation-panel">
        <MemberPanel Members="_invMembers"
                     RemediationMembers="_remMembers"
                     SelectedId="@(_activeRoom == "remediation" ? $"rem:{_selectedMemberId}" : _selectedMemberId)"
                     OnSelect="OnMemberSelected" />
        <div class="conversation-messages" @ref="_messagesRef">
            <Virtualize Items="_filteredItems" Context="item" OverscanCount="5">
                <ChatMessage @key="item" Item="item" Members="_activeMembers" OnStepClick="ScrollToLogEntry" ShowUsage="_isAgentSelected" ConversationId="ConversationId" />
            </Virtualize>
        </div>
        @if (_interactive && _isOwner && _selectedMemberId is "all")
        {
            <div class="input-divider" @ref="_inputDividerRef"></div>
            <ChatInput OnSend="OnSendAsync" OnCancel="OnCancel"
                       IsInvestigating="_isInvestigating"
                       HasWorkingAgents="_hasWorkingAgents"
                       IsRemediation="_isRemediation" />
        }
        else if (_interactive && _isOwner && _isScoutSelected)
        {
            <div class="input-divider" @ref="_inputDividerRef"></div>
            <div class="chat-input">
                <div class="chat-input-row scout-actions">
                    <button class="btn-send" @onclick="() => OnRecallScout(_selectedScout!.Name)"
                            disabled="@(!_selectedScoutIsWorking || _scoutActionInFlight)"
                            title="Little Bear recalls this Scout to report back.">Recall</button>
                    <button class="btn-cancel" @onclick="() => OnStandDownScout(_selectedScout!.Name)"
                            disabled="@(!_selectedScoutIsWorking || _scoutActionInFlight)"
                            title="Little Bear stands this Scout down immediately.">Stand Down</button>
                </div>
            </div>
        }
    </div>

    <div class="panel-divider" @ref="_dividerRef"></div>

    <div class="log-panel">
        @if (_isRemediation && _selectedMemberId == "all")
        {
            <div class="log-header">
                <span>Remediation Plan</span>
                @if (_isOwner)
                {
                    <button class="btn-share-readonly" @onclick="CopyShareLink" title="Copy read-only link to clipboard">
                        @(_shareCopied ? "Copied!" : "Share Record")
                    </button>
                }
            </div>
            <div class="log-entries plan-panel-container" @ref="_logRef">
                <PlanPanel Plan="ActiveView.Plan" SignedOff="ActiveView.Items.Any(i => i is ConversationItem.SignOffItem)" ConversationId="ConversationId" />
            </div>
        }
        else if (_showFindings)
        {
            <div class="log-header">
                <span>Findings</span>
                @if (_isOwner)
                {
                    <button class="btn-share-readonly" @onclick="CopyShareLink" title="Copy read-only link to clipboard">
                        @(_shareCopied ? "Copied!" : "Share Record")
                    </button>
                }
            </div>
            <div class="log-entries findings-panel" @ref="_logRef">
                @foreach (var item in FilteredFindings)
                {
                    var isConclusion = item is ConversationItem.Conclusion;
                    var expanded = IsFindingExpanded(item);
                    var summaryText = item switch
                    {
                        ConversationItem.Finding f => f.Summary ?? Truncate($"**{f.Title}**\n{f.Description}"),
                        ConversationItem.Conclusion c => c.Headline ?? Truncate(c.Content),
                        _ => "",
                    };
                    var fullText = item switch
                    {
                        ConversationItem.Finding f => $"**{f.Title}**\n{f.Description}",
                        ConversationItem.Conclusion c => c.Content,
                        _ => "",
                    };
                    <div @key="item" class="finding-entry @(isConclusion ? "finding-conclusion" : "")" @onclick="() => ToggleFinding(item)">
                        <div class="finding-header">
                            <span class="finding-chevron toggle-arrow">@(expanded ? "▼" : "▶")</span>
                            @if (isConclusion)
                            {
                                <span class="finding-label conclusion-label">Conclusion</span>
                            }
                            <span class="finding-summary"><MarkdownRenderer Content="@summaryText" Inline="true" /></span>
                            @if (isConclusion && _interactive && _isOwner && !_isInvestigating && !_isRemediation && _session?.Remediation is null)
                            {
                                var c = (ConversationItem.Conclusion)item;
                                <button class="btn-transfer-new"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => CommissionRemedyFromUI(c)"
                                        title="Commission The Canopy Post to begin remediation">
                                    Commission The Canopy Post
                                </button>
                            }
                        </div>
                        @if (expanded)
                        {
                            <div class="finding-full">
                                <MarkdownRenderer Content="@fullText" />
                            </div>
                        }
                        <div class="finding-time">@BrowserTz.ToLocal(item.Timestamp).ToString("HH:mm:ss")</div>
                    </div>
                }
                @if (!FilteredFindings.Any())
                {
                    <div class="log-empty">Findings will appear here as the investigation proceeds.</div>
                }
            </div>
        }
        else
        {
            <div class="log-header">
                Investigation Log
                @if (_selectedMemberId != "all")
                {
                    <span class="log-filter-badge">@(_activeMembers.FirstOrDefault(m => m.Id == _selectedMemberId)?.Name ?? _selectedMemberId)</span>
                }
            </div>
            <div class="log-entries" @ref="_logRef">
                <Virtualize Items="_filteredLogItems" Context="entry" OverscanCount="5">
                    <LogEntry @key="entry" Entry="entry" Members="_activeMembers" HighlightedStepId="_highlightedStepId" ConversationId="ConversationId" />
                </Virtualize>
                @if (_filteredLogItems.Count == 0)
                {
                    <div class="log-empty">Inquiries will appear here when you select a member.</div>
                }
            </div>
        }
        @{ var av = ActiveView; }
        @if (av.TotalCost > 0)
        {
            @if (_selectedMemberId == "all")
            {
                <CostPanel UsageByAgent="av.UsageByAgent" Members="av.Members"
                           TotalCost="av.TotalCost" />
            }
            else
            {
                var agentUsage = GetSelectedAgentUsage();
                @if (agentUsage is not null)
                {
                    <CostPanel SelectedAgent="agentUsage" />
                }
            }
        }
    </div>
</div>

</div>
