@page "/c/{ConversationId}"
@page "/c/{ConversationId}/view"
@using Investigator.Models
@using Investigator.Components.Conversation
@using Investigator.Components.InvestigationLog
@using Investigator.Components.Shared

<PageTitle>Little Bear, the Detective</PageTitle>

<div class="chat-page @(!_isOwner ? "readonly" : "")">

@if (!_isOwner && _session is not null)
{
    <div class="readonly-banner">
        <span>Viewing a shared record of this investigation (read-only)</span>
        @if (!_forcedReadonly)
        {
            <button class="btn-refresh" @onclick="Refresh">Refresh</button>
        }
    </div>
}

<div class="investigator-layout">
    <div class="conversation-panel">
        <MemberPanel Members="_members" SelectedId="_selectedMemberId" OnSelect="OnMemberSelected"
                     OnRecall="OnRecallScout" OnStandDown="OnStandDownScout" />
        <div class="conversation-messages" @ref="_messagesRef">
            @foreach (var item in FilteredConversation)
            {
                <ChatMessage Item="item" OnStepClick="ScrollToLogEntry" />
            }
        </div>
        @if (_isOwner && _selectedMemberId is "all" or "user")
        {
            <div class="input-divider" @ref="_inputDividerRef"></div>
            <ChatInput OnSend="OnSendAsync" OnCancel="OnCancel"
                       IsInvestigating="_isInvestigating"
                       HasWorkingAgents="_hasWorkingAgents" />
        }
    </div>

    <div class="panel-divider" @ref="_dividerRef"></div>

    <div class="log-panel">
        @if (_showFindings)
        {
            <div class="log-header">
                <span>Findings</span>
                @if (_isOwner)
                {
                    <button class="btn-share-readonly" @onclick="CopyShareLink" title="Copy read-only link to clipboard">
                        @(_shareCopied ? "Copied!" : "Share Record")
                    </button>
                }
            </div>
            <div class="log-entries findings-panel" @ref="_logRef">
                @foreach (var item in FilteredFindings)
                {
                    var isConclusion = item.Type == ConversationItemType.Conclusion;
                    var expanded = IsFindingExpanded(item);
                    <div class="finding-entry @(isConclusion ? "finding-conclusion" : "")" @onclick="() => ToggleFinding(item)">
                        <div class="finding-header">
                            <span class="finding-chevron toggle-arrow">@(expanded ? "▼" : "▶")</span>
                            @if (isConclusion)
                            {
                                <span class="finding-label conclusion-label">Conclusion</span>
                            }
                            <span class="finding-summary"><MarkdownRenderer Content="@(item.Summary ?? Truncate(item.Content))" Inline="true" /></span>
                        </div>
                        @if (expanded)
                        {
                            <div class="finding-full">
                                <MarkdownRenderer Content="@item.Content" />
                            </div>
                        }
                        <div class="finding-time">@item.Timestamp.ToString("HH:mm:ss")</div>
                    </div>
                }
                @if (!FilteredFindings.Any())
                {
                    <div class="log-empty">Findings will appear here as the investigation proceeds.</div>
                }
            </div>
        }
        else
        {
            <div class="log-header">
                Investigation Log
                @if (_selectedMemberId != "all" && _selectedMemberId != "user")
                {
                    <span class="log-filter-badge">@(_members.FirstOrDefault(m => m.Id == _selectedMemberId)?.Name ?? _selectedMemberId)</span>
                }
            </div>
            <div class="log-entries" @ref="_logRef">
                @foreach (var entry in FilteredLog)
                {
                    <LogEntry Entry="entry" HighlightedStepId="_highlightedStepId" />
                }
                @if (!FilteredLog.Any())
                {
                    <div class="log-empty">Inquiries will appear here when you select a member.</div>
                }
            </div>
        }
    </div>
</div>

</div>
