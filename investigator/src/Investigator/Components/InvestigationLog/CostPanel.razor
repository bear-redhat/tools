@using Investigator.Services

@if (SelectedAgent is not null)
{
    <div class="cost-panel" @onclick="Toggle">
        <div class="cost-panel-header">
            <span class="toggle-arrow">@(_expanded ? "▼" : "▶")</span>
            <span class="cost-panel-total">@FormatCost(SelectedAgent.Cost)</span>
            @if (SelectedAgent.ModelProfile is not null)
            {
                <span class="cost-panel-model">@SelectedAgent.ModelProfile</span>
            }
            @if (!_expanded)
            {
                <span class="cost-panel-hint">@FormatTokens(SelectedAgent.InputTokens) in @FormatTokens(SelectedAgent.OutputTokens) out@(SelectedAgent.CacheReadTokens > 0 ? $" {FormatTokens(SelectedAgent.CacheReadTokens)} cached" : "")</span>
            }
        </div>
        @if (_expanded)
        {
            <div class="cost-panel-body" @onclick:stopPropagation="true">
                <div class="cost-row">
                    <span class="cost-row-name">Input</span>
                    <span class="cost-row-amount">@FormatCost(TokenCost(SelectedAgent.InputTokens, SelectedAgent.InputPricePerMToken))</span>
                    <span class="cost-row-tokens">@FormatTokens(SelectedAgent.InputTokens) tokens</span>
                </div>
                <div class="cost-row">
                    <span class="cost-row-name">Output</span>
                    <span class="cost-row-amount">@FormatCost(TokenCost(SelectedAgent.OutputTokens, SelectedAgent.OutputPricePerMToken))</span>
                    <span class="cost-row-tokens">@FormatTokens(SelectedAgent.OutputTokens) tokens</span>
                </div>
                @if (SelectedAgent.CacheReadTokens > 0)
                {
                    <div class="cost-row">
                        <span class="cost-row-name">Cache Read</span>
                        <span class="cost-row-amount">@FormatCost(TokenCost(SelectedAgent.CacheReadTokens, SelectedAgent.CacheReadPricePerMToken))</span>
                        <span class="cost-row-tokens">@FormatTokens(SelectedAgent.CacheReadTokens) tokens</span>
                    </div>
                }
                @if (SelectedAgent.CacheCreateTokens > 0)
                {
                    <div class="cost-row">
                        <span class="cost-row-name">Cache Write</span>
                        <span class="cost-row-amount">@FormatCost(TokenCost(SelectedAgent.CacheCreateTokens, SelectedAgent.CacheCreationPricePerMToken))</span>
                        <span class="cost-row-tokens">@FormatTokens(SelectedAgent.CacheCreateTokens) tokens</span>
                    </div>
                }
                <div class="cost-row cost-row-total">
                    <span class="cost-row-name">Total</span>
                    <span class="cost-row-amount">@FormatCost(SelectedAgent.Cost)</span>
                    <span class="cost-row-tokens"></span>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="cost-panel" @onclick="Toggle">
        <div class="cost-panel-header">
            <span class="toggle-arrow">@(_expanded ? "▼" : "▶")</span>
            <span class="cost-panel-total">@FormatCost(TotalCost)</span>
            @if (!_expanded)
            {
                <span class="cost-panel-hint">@FormatTokens(TotalInputTokens) in @FormatTokens(TotalOutputTokens) out@(TotalCacheReadTokens > 0 ? $" {FormatTokens(TotalCacheReadTokens)} cached" : "")@(TotalCacheCreateTokens > 0 ? $" {FormatTokens(TotalCacheCreateTokens)} cache-write" : "")</span>
            }
        </div>
        @if (_expanded)
        {
            <div class="cost-panel-body" @onclick:stopPropagation="true">
                @foreach (var (name, usage) in UsageByAgent.OrderByDescending(kv => kv.Value.Cost))
                {
                    <div class="cost-row">
                        <span class="cost-row-name">@name</span>
                        <span class="cost-row-amount">@FormatCost(usage.Cost)</span>
                        <span class="cost-row-tokens">@FormatTokens(usage.InputTokens) in @FormatTokens(usage.OutputTokens) out@(usage.CacheReadTokens > 0 ? $" {FormatTokens(usage.CacheReadTokens)} cached" : "")@(usage.CacheCreateTokens > 0 ? $" {FormatTokens(usage.CacheCreateTokens)} cache-write" : "")</span>
                    </div>
                }
                @if (PanelSummarizationUsage.Cost > 0)
                {
                    <div class="cost-row">
                        <span class="cost-row-name">Panel Summaries</span>
                        <span class="cost-row-amount">@FormatCost(PanelSummarizationUsage.Cost)</span>
                        <span class="cost-row-tokens">@FormatTokens(PanelSummarizationUsage.InputTokens) in @FormatTokens(PanelSummarizationUsage.OutputTokens) out@(PanelSummarizationUsage.CacheReadTokens > 0 ? $" {FormatTokens(PanelSummarizationUsage.CacheReadTokens)} cached" : "")@(PanelSummarizationUsage.CacheCreateTokens > 0 ? $" {FormatTokens(PanelSummarizationUsage.CacheCreateTokens)} cache-write" : "")</span>
                    </div>
                }
                <div class="cost-row cost-row-total">
                    <span class="cost-row-name">Total</span>
                    <span class="cost-row-amount">@FormatCost(TotalCost)</span>
                    <span class="cost-row-tokens">@FormatTokens(TotalInputTokens) in @FormatTokens(TotalOutputTokens) out@(TotalCacheReadTokens > 0 ? $" {FormatTokens(TotalCacheReadTokens)} cached" : "")@(TotalCacheCreateTokens > 0 ? $" {FormatTokens(TotalCacheCreateTokens)} cache-write" : "")</span>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Dictionary<string, AgentUsage> UsageByAgent { get; set; } = new();
    [Parameter] public AgentUsage PanelSummarizationUsage { get; set; } = new();
    [Parameter] public decimal TotalCost { get; set; }
    [Parameter] public AgentUsage? SelectedAgent { get; set; }

    private bool _expanded;
    private void Toggle() => _expanded = !_expanded;

    private int TotalInputTokens =>
        UsageByAgent.Values.Sum(u => u.InputTokens) + PanelSummarizationUsage.InputTokens;
    private int TotalOutputTokens =>
        UsageByAgent.Values.Sum(u => u.OutputTokens) + PanelSummarizationUsage.OutputTokens;
    private int TotalCacheReadTokens =>
        UsageByAgent.Values.Sum(u => u.CacheReadTokens) + PanelSummarizationUsage.CacheReadTokens;
    private int TotalCacheCreateTokens =>
        UsageByAgent.Values.Sum(u => u.CacheCreateTokens) + PanelSummarizationUsage.CacheCreateTokens;

    private static decimal TokenCost(int tokens, decimal pricePerMToken) =>
        tokens * pricePerMToken / 1_000_000m;

    private static string FormatCost(decimal cost) =>
        cost < 0.01m ? $"${cost:F4}" : $"${cost:F2}";

    private static string FormatTokens(int tokens) =>
        tokens >= 1000 ? $"{tokens / 1000.0:F1}k" : tokens.ToString("N0");
}
