@using System.Globalization
@using Investigator.Components.Shared
@using Investigator.Models
@using Investigator.Services
@inject BrowserTimeZone BrowserTz

<div class="log-entry @GetStatusClass() @(IsHighlighted ? "highlighted" : "")" id="@Entry.StepId">
    <div class="log-entry-header" @onclick="Toggle">
        <span class="log-entry-num">#@GetEntryNumber()</span>
        <span class="log-entry-agent">@DisplayName(Entry.Sender)</span>
        <span class="log-entry-tool">@Entry.Tool</span>
        @if (Entry.Context is not null)
        {
            @foreach (var tag in Entry.Context)
            {
                <span class="log-entry-tag" title="@tag.Key">@tag.Value</span>
            }
        }
        <span class="log-entry-status">@GetStatusIcon()</span>
        @if (Entry.Usage is { Cost: > 0 })
        {
            <span class="log-entry-cost" title="@FormatTokens(Entry.Usage.InputTokens) in / @FormatTokens(Entry.Usage.OutputTokens) out">@FormatCost(Entry.Usage.Cost)</span>
        }
        @if (Entry.Usage is { CompactionBefore: not null, CompactionAfter: not null })
        {
            <span class="log-entry-compaction" title="Context window compaction">~@Entry.Usage.CompactionBefore → ~@Entry.Usage.CompactionAfter</span>
        }
        <span class="log-entry-time">@BrowserTz.ToLocal(Entry.Timestamp).ToString("HH:mm:ss")</span>
    </div>
    <div class="log-entry-command">
        <code>@Entry.DisplayCommand</code>
        <CopyButton Text="@Entry.DisplayCommand" />
        @if (Entry.OutputFile is not null && ConversationId is not null)
        {
            <a class="log-entry-file-link" href="/api/conversations/@ConversationId/files/@Entry.OutputFile"
               target="_blank" title="View full output">📄</a>
        }
    </div>

    @if (_expanded && Entry.Output is not null)
    {
        <div class="log-entry-output">
            <pre>@Entry.Output</pre>
        </div>
    }

    @if (_expanded && Entry.Children is { Count: > 0 })
    {
        <div class="log-entry-children">
            @foreach (var child in Entry.Children)
            {
                <LogEntry Entry="child" Members="Members" HighlightedStepId="HighlightedStepId" ConversationId="ConversationId" />
            }
        </div>
    }

    @if (Entry.Status == LogEntryStatus.Running)
    {
        <div class="log-entry-spinner">Executing...</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LogEntryModel Entry { get; set; } = default!;
    [Parameter] public IReadOnlyList<GroupMember>? Members { get; set; }
    [Parameter] public string? HighlightedStepId { get; set; }
    [Parameter] public string? ConversationId { get; set; }

    private string DisplayName(string? id) =>
        Members?.FirstOrDefault(m => m.Id == id)?.Name
        ?? CultureInfo.InvariantCulture.TextInfo.ToTitleCase((id ?? "").Replace("-", " "));
    private bool _expanded;

    private bool IsHighlighted => HighlightedStepId == Entry.StepId;

    private void Toggle() => _expanded = !_expanded;

    private string GetStatusClass() => Entry.Status switch
    {
        LogEntryStatus.Running => "running",
        LogEntryStatus.Completed => Entry.ExitCode == 0 ? "success" : "failed",
        LogEntryStatus.TimedOut => "timed-out",
        _ => "",
    };

    private string GetStatusIcon() => Entry.Status switch
    {
        LogEntryStatus.Running => "⏳",
        LogEntryStatus.Completed => Entry.ExitCode == 0 ? "✓" : "✗",
        LogEntryStatus.TimedOut => "⏰",
        _ => "",
    };

    private string GetEntryNumber() => Entry.StepId.Replace("step-", "").Replace("sa-", "");

    private static string FormatCost(decimal cost) =>
        cost < 0.01m ? $"${cost:F4}" : $"${cost:F3}";

    private static string FormatTokens(int tokens) =>
        tokens >= 1000 ? $"{tokens / 1000.0:F1}k" : tokens.ToString("N0");
}
