{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Tools": {
    "run_aws": {},
    "run_oc": {
      "Clusters": [
      ]
    },
    "ci_repo": {
      "Repos": {
        "release": { "LocalPath": "/data/release-repo", "ShallowClone": false },
        "ci-tools": { "LocalPath": "/data/ci-tools-repo", "ShallowClone": false }
      }
    },
    "skills": {
      "Path": "skills"
    }
  },

  "Workspace": {
    "RootPath": "/data/investigator/workspaces"
  },

  "Llm": {
    "Primary": "claude-opus",
    "Default": "claude-sonnet",
    "Summarizer": "claude-sonnet",
    "Providers": {
      "bedrock": {}
    },
    "Models": {
      "claude-opus": {
        "Provider": "bedrock",
        "Region": "us-east-1",
        "Model": "us.anthropic.claude-opus-4-6-v1",
        "EmbeddingModel": "amazon.titan-embed-text-lite-v2:0",
        "MaxTokens": 128000,
        "ThinkingBudget": 32000,
        "Strengths": "Deep reasoning, complex multi-step analysis, tool orchestration"
      },
      "claude-sonnet": {
        "Provider": "bedrock",
        "Region": "us-east-1",
        "Model": "us.anthropic.claude-sonnet-4-6",
        "MaxTokens": 32000,
        "ThinkingBudget": 16000,
        "Strengths": "Fast, cheap, good enough for straightforward tasks like log fetching, config reading, simple lookups"
      },
      "gpt": {
        "Provider": "bedrock",
        "Region": "us-east-1",
        "Model": "openai.gpt-5.4",
        "MaxTokens": 16000,
        "Strengths": "Fast coding, structured output, broad general knowledge"
      }
    }
  },

  "Agent": {
    "MaxToolCalls": 256
  }
}
